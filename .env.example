# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# MongoDB Atlas connection string (include database name in the path,
# e.g. mongodb+srv://user:pass@cluster.mongodb.net/jatra?retryWrites=true&w=majority)
DATABASE_URL="mongodb+srv://USER:PASS@CLUSTER.mongodb.net/jatra?retryWrites=true&w=majority"

# Generate a long random string (32+ chars). Use `openssl rand -base64 48` or any password generator.
JWT_SECRET="generate-a-long-random-string-here"

NEXT_PUBLIC_APP_NAME="যাত্রা"
